# ============================================================================
# Environment Configuration Template for MicroGrid Pro
# ============================================================================
# USAGE:
#   1. Copy this file to the root directory and name it: .env
#   2. Fill in your configuration values below
#   3. Do NOT commit .env to version control
#   4. For production, set ENVIRONMENT=production and adjust settings accordingly
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & GENERAL
# ─────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Set to: development, staging, production

APP_NAME="MicroGrid Pro"
APP_URL="http://localhost/microgrid"
APP_VERSION="1.0.0"

# ─────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=microgrid_platform
DB_USER=root
DB_PASS=
DB_PORT=3306
DB_CHARSET=utf8mb4

# ─────────────────────────────────────────────────────────────────────────
# SECURITY & HTTPS
# ─────────────────────────────────────────────────────────────────────────
# Force HTTPS in production
FORCE_HTTPS=false
# Set to: true (for production), false (for development)

# Security headers
HSTS_MAX_AGE=31536000
# HTTP Strict Transport Security max age in seconds (default: 1 year)

CSP_ENABLED=true
# Content Security Policy enabled (recommended for production)

# ─────────────────────────────────────────────────────────────────────────
# SESSION & AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
# Session timeout in minutes (default: 30 minutes)

SESSION_COOKIE_SECURE=false
# Set to true in production (requires HTTPS)

SESSION_COOKIE_HTTPONLY=true
# Only send session cookie over HTTP (not JavaScript)

# ─────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Set to: debug, info, warning, error, critical

LOG_FILE="logs/app.log"
LOG_MAX_SIZE=10485760
# Maximum log file size in bytes (default: 10MB)

LOG_BACKUP_COUNT=5
# Number of log backups to retain (default: 5)

LOG_DISPLAY_ERRORS=false
# Display error details in browser (set false in production!)

# ─────────────────────────────────────────────────────────────────────────
# EMAIL NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────────
MAIL_ENABLED=false
# Enable email notifications for alerts (true/false)

MAIL_FROM="noreply@microgrid.local"
# Sender email address

MAIL_FROM_NAME="MicroGrid Pro"
# Sender display name

MAIL_METHOD="php"
# Email delivery method: php (built-in mail()) or smtp
# php    = Uses server's mail() function (requires sendmail/postfix configured)
# smtp   = Uses SMTP connection (requires SMTP_HOST, SMTP_USER, SMTP_PASS)

# ─────────────────────────────────────────────────────────────────────────
# SMTP CONFIGURATION (if MAIL_METHOD=smtp)
# ─────────────────────────────────────────────────────────────────────────
SMTP_HOST=""
# SMTP server hostname (e.g., smtp.gmail.com, mail.example.com)

SMTP_PORT=587
# SMTP port (typically 25, 465, or 587)
# 25   = Plain SMTP (unencrypted)
# 465  = SMTPS (encrypted)
# 587  = SMTP with STARTTLS (recommended)

SMTP_USER=""
# SMTP username (usually email address)

SMTP_PASS=""
# SMTP password

# ─────────────────────────────────────────────────────────────────────────
# EMAIL LOGGING
# ─────────────────────────────────────────────────────────────────────────
MAIL_LOG_SENT=true
# Log all sent emails to file (true/false)

MAIL_LOG_FILE="logs/email.log"
# Path to email log file

# ─────────────────────────────────────────────────────────────────────────
# API RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
# Enable API rate limiting (true/false)

RATE_LIMIT_WINDOW=60
# Rate limit window in seconds (default: 60 seconds)

RATE_LIMIT_MAX_REQUESTS=100
# Maximum requests per window for analytics/health endpoints

RATE_LIMIT_MAX_IOT=100
# Maximum requests per window for IoT sensor endpoints

# ─────────────────────────────────────────────────────────────────────────
# BACKUP CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
# Enable automated backups (true/false)

BACKUP_COMPRESS=true
# Compress backups with ZIP (if available)

BACKUP_RETENTION_DAYS=7
# Days to retain backup files (default: 7 days)

BACKUP_LOG_FILE="database/backups/backup.log"
# Path to backup log file

# ─────────────────────────────────────────────────────────────────────────
# 2FA (TWO-FACTOR AUTHENTICATION)
# ─────────────────────────────────────────────────────────────────────────
TWO_FA_ENABLED=true
# Enable 2FA support (true/false)
# Users can optionally enable 2FA on their accounts

TWO_FA_OPTIONAL=true
# Make 2FA optional (true) or required (false)

TWO_FA_BACKUP_CODES_COUNT=8
# Number of backup codes to generate (default: 8)

TWO_FA_WINDOW=1
# Time window tolerance in 30-second intervals (±1 = 90 seconds total)

# ─────────────────────────────────────────────────────────────────────────
# DATA RETENTION POLICIES
# ─────────────────────────────────────────────────────────────────────────
RETENTION_ENABLED=true
# Enable automated data cleanup based on retention policies

RETENTION_ALERT_DAYS=90
# Keep resolved alerts for N days (default: 90 days = ~3 months)

RETENTION_READING_DAYS=365
# Keep energy readings for N days (default: 365 days = 1 year)
# Older readings are automatically deleted to save storage

RETENTION_BATTERY_DAYS=90
# Keep battery status records for N days (default: 90 days = ~3 months)

RETENTION_LOG_DAYS=30
# Keep system logs for N days (default: 30 days = 1 month)
# Info logs deleted first, critical/warning preserved longer

RETENTION_EMAIL_LOG_DAYS=180
# Keep email notification logs for N days (default: 180 days = ~6 months)
# Failed emails retained longer for diagnostics

RETENTION_NOTIFICATION_LOG_DAYS=90
# Keep email notification queue entries for N days (default: 90 days)

RETENTION_DRY_RUN=false
# Preview cleanup without actually deleting (true/false)

# ─────────────────────────────────────────────────────────────────────────
# SAMPLE SMTP CONFIGURATIONS
# ─────────────────────────────────────────────────────────────────────────
#
# GMAIL:
#   MAIL_METHOD=smtp
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASS=your-app-password (NOT regular password!)
#   Note: Enable "Less secure app access" or use 2FA app passwords
#
# OFFICE 365:
#   MAIL_METHOD=smtp
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@company.onmicrosoft.com
#   SMTP_PASS=your-password
#
# SENDGRID:
#   MAIL_METHOD=smtp
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=your-sendgrid-api-key
#
# LOCAL POSTFIX/SENDMAIL:
#   MAIL_METHOD=php
#   MAIL_FROM=noreply@yourdomain.com
#   (No SMTP config needed - uses system mail)
#
# ============================================================================
